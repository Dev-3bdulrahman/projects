{
    "name": "dev-3bdulrahman/projects",
    "description": "A Project Management module for Laravel ERP — projects, tasks, kanban, timesheets & expenses.",
    "type": "library",
    "version": "1.0.2",
    "license": "MIT",
    "authors": [
        {
            "name": "Abdulrahman",
            "homepage": "https://3bdulrahman.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2|^8.3",
        "laravel/framework": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Dev3bdulrahman\\Projects\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dev3bdulrahman\\Projects\\Providers\\ProjectsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
